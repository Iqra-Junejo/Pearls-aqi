# ── OpenWeather API ─────────────────────────────────
# Free key → https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# ── Hopsworks (Feature Store + Model Registry) ───────
# Free tier → https://www.hopsworks.ai
# After signup: Account Settings → API Key
HOPSWORKS_API_KEY=your_hopsworks_api_key_here
HOPSWORKS_PROJECT=pearls_aqi

# ── City ─────────────────────────────────────────────
CITY=karachi
CITY_LAT=24.8607
CITY_LON=67.0011

# ── Flask ─────────────────────────────────────────────
FLASK_SECRET_KEY=change-this-to-anything-random
PORT=5000
FLASK_ENV=development
